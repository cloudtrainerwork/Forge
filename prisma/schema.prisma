// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Basic health check model to ensure connection works
model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("healthy")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("health_checks")
}

// Work item model with flexible JSONB spec and readiness tracking
model WorkItem {
  id                      String                   @id @default(cuid())
  title                   String?
  description             String?
  spec                    Json                     @db.JsonB // Flexible work item specifications
  readiness               Json                     @db.JsonB // 6-dimensional readiness tracking
  readinessConfigurationId String?                  @map("readiness_configuration_id")
  readinessConfiguration   ReadinessConfiguration? @relation(fields: [readinessConfigurationId], references: [id])
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@map("work_items")
}

// Readiness configuration for custom states and validation rules
model ReadinessConfiguration {
  id              String     @id @default(cuid())
  name            String     @unique
  description     String?
  states          Json       @db.JsonB // StateConfiguration[]
  validationRules Json       @db.JsonB // ValidationRule[]
  workItems       WorkItem[]
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("readiness_configurations")
}

// Audit log for complete traceability
model AuditLog {
  id        String        @id @default(cuid())
  type      AuditLogType  // What kind of change happened
  entityId  String        @map("entity_id") // ID of the affected entity
  changes   Json          @db.JsonB // What changed (before/after, metadata)
  timestamp DateTime      @default(now())

  @@map("audit_logs")
}

enum AuditLogType {
  WORK_ITEM_CREATED
  WORK_ITEM_UPDATED
  RELATIONSHIP_ADDED
  RELATIONSHIP_REMOVED
  READINESS_UPDATED
  READINESS_CONFIG_CREATED
  READINESS_CONFIG_UPDATED
}